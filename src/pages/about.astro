---
import BaseLayout from '../layouts/BaseLayout.astro';

// Edit these to update About content
const bio = [
  `I'm a motion designer and illustrator based in the U.S., with roots in
  Taiwan. My work blends warmth, character, and a quiet sense of play —
  whether I'm helping a brand tell a clearer story or building a little
  world of my own.`,

  `I currently make motion at Instrument. Before that, I studied at SVA
  in New York and freelanced for studios and brands across broadcast,
  tech, and publishing.`,

  `When I'm not animating, you'll find me sketching, learning new tools
  (currently Rive), or wandering through bookshops collecting picture
  books for "research."`,
];

const clients = [
  'NPR', 'Google', 'Adobe', 'The New York Times', 'Spotify',
  'Netflix', 'Headspace', 'Mailchimp',
];

const recognition = [
  { year: '2024', what: 'Motion Awards — Nominee, Best Brand Film' },
  { year: '2023', what: 'Vimeo Staff Pick' },
  { year: '2022', what: 'Communication Arts — Featured' },
];
---

<BaseLayout title="About — Bella Shih" description="About Bella Shih, motion designer and illustrator.">
  <section class="about-page container-narrow">
    <header class="about-header">
      <p class="page-eyebrow">About</p>
      <h1 class="about-title">
        Hi! I'm <span class="title-mark">Bella</span> ✦
      </h1>
    </header>

    <div class="about-grid">
      <div class="about-portrait">
        <!-- Replace this with a real headshot or self-portrait illustration.
             Drop the file in /public/images/about.jpg and update the src. -->
        <div class="portrait-placeholder">
          <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
            <rect width="200" height="200" fill="#B8BC59"/>
            <circle cx="100" cy="80" r="35" fill="#FAF7E8"/>
            <path d="M50,200 Q50,130 100,130 Q150,130 150,200 Z" fill="#FAF7E8"/>
            <circle cx="170" cy="50" r="12" fill="#FF6B2B"/>
          </svg>
        </div>
      </div>

      <div class="about-text">
        {bio.map(paragraph => <p>{paragraph}</p>)}
      </div>
    </div>

    <div class="about-cols">
      <div class="about-col">
        <h2 class="col-title">Selected clients</h2>
        <ul class="col-list">
          {clients.map(client => <li>{client}</li>)}
        </ul>
      </div>

      <div class="about-col">
        <h2 class="col-title">Recognition</h2>
        <ul class="col-list">
          {recognition.map(item => (
            <li>
              <span class="recognition-year">{item.year}</span>
              {item.what}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="about-cta">
      <h2 class="cta-title">Let's make something together.</h2>
      <a href="mailto:hello@bellashih.com" class="cta-email">hello@bellashih.com →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page {
    padding: var(--space-xl) var(--space-md);
  }

  .about-header {
    margin-bottom: var(--space-xl);
  }

  .page-eyebrow {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-pop);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .about-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(3rem, 7vw, 5.5rem);
    letter-spacing: -0.035em;
    color: var(--color-ink);
    font-variation-settings: 'opsz' 72;
  }

  .title-mark {
    position: relative;
    display: inline-block;
    color: var(--color-pop);
  }

  .title-mark::after {
    content: '';
    position: absolute;
    left: -2px;
    right: -2px;
    bottom: 0.08em;
    height: 0.2em;
    background: var(--color-accent);
    z-index: -1;
    transform: skewX(-6deg);
  }

  /* PORTRAIT + BIO LAYOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-lg);
    align-items: start;
    margin-bottom: var(--space-2xl);
  }

  .about-portrait {
    position: sticky;
    top: 100px;
  }

  .portrait-placeholder {
    aspect-ratio: 1;
    border-radius: 16px;
    overflow: hidden;
    background: var(--color-accent);
  }

  .about-text p {
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
    margin-bottom: 1.25rem;
    max-width: none;
  }

  .about-text p:first-child {
    font-size: 1.25rem;
    color: var(--color-ink);
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .about-portrait {
      position: static;
      max-width: 280px;
    }
  }

  /* CLIENTS + RECOGNITION COLUMNS */
  .about-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border-color);
    margin-bottom: var(--space-2xl);
  }

  .col-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.95rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-md);
  }

  .col-list {
    list-style: none;
    font-size: 1rem;
    color: var(--color-ink-soft);
  }

  .col-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .recognition-year {
    display: inline-block;
    width: 60px;
    font-weight: 500;
    color: var(--color-ink);
  }

  @media (max-width: 640px) {
    .about-cols { grid-template-columns: 1fr; gap: var(--space-md); }
  }

  /* CTA */
  .about-cta {
    text-align: center;
    padding: var(--space-xl) 0;
  }

  .cta-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 5vw, 3.5rem);
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin-bottom: var(--space-md);
    font-variation-settings: 'opsz' 72;
  }

  .cta-email {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: var(--color-pop);
    text-decoration: none;
    border-bottom: 2px solid var(--color-pop);
    padding-bottom: 4px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .cta-email:hover {
    color: var(--color-ink);
    border-color: var(--color-ink);
  }
</style>
