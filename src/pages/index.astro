---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectTile from '../components/ProjectTile.astro';
import { getCollection } from 'astro:content';

const workProjects = (await getCollection('work', ({ data }) => !data.draft && data.featured))
  .sort((a, b) => a.data.order - b.data.order);

const personalProjects = (await getCollection('personal', ({ data }) => !data.draft && data.featured))
  .sort((a, b) => a.data.order - b.data.order);

const featured = [...workProjects, ...personalProjects].slice(0, 6);

// Feature on top + rest in masonry
const featureProject = featured.find(p => p.data.size === 'feature');
const restProjects = featured.filter(p => p !== featureProject);
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero container">
    <div class="hero-content">
      <p class="hero-eyebrow">Hi, I'm Bella ✦</p>
      <h1 class="hero-title">
        A motion designer<br />
        <span class="hero-italic">turning ideas</span><br />
        into <span class="hero-mark">moving images.</span>
      </h1>
      <p class="hero-sub">
        I help brands, broadcasters, and storytellers bring concepts to life
        through animation, illustration, and a healthy dose of curiosity.
      </p>
      <div class="hero-actions">
        <a href="/work" class="btn btn-primary">See my work</a>
        <a href="/reel" class="btn btn-ghost">Watch reel →</a>
      </div>
    </div>

    <div class="hero-decor" aria-hidden="true">
      <div class="decor-shape decor-circle"></div>
      <div class="decor-shape decor-blob"></div>
      <div class="decor-shape decor-dot"></div>
    </div>
  </section>

  <!-- FEATURED PROJECTS -->
  {featured.length > 0 && (
    <section class="featured container">
      <header class="section-header">
        <h2 class="section-title">Selected work</h2>
        <a href="/work" class="section-link">All projects →</a>
      </header>

      {featureProject && (
        <div class="feature-row">
          <ProjectTile
            href={`/projects/${featureProject.id}`}
            title={featureProject.data.title}
            client={featureProject.data.client}
            year={featureProject.data.year?.toString()}
            tags={featureProject.data.tags}
            thumbnail={featureProject.data.thumbnail}
            hoverVideo={featureProject.data.hoverVideo}
            size="feature"
          />
        </div>
      )}

      {restProjects.length > 0 && (
        <div class="masonry">
          {restProjects.map(project => (
            <ProjectTile
              href={`/projects/${project.id}`}
              title={project.data.title}
              client={project.data.client}
              year={project.data.year?.toString()}
              tags={project.data.tags}
              thumbnail={project.data.thumbnail}
              hoverVideo={project.data.hoverVideo}
              size={project.data.size === 'feature' ? 'landscape' : project.data.size}
            />
          ))}
        </div>
      )}
    </section>
  )}
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    padding: var(--space-2xl) var(--space-md);
    min-height: 70vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-content { position: relative; z-index: 2; max-width: 900px; }
  .hero-eyebrow {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-pop);
    margin-bottom: var(--space-sm);
    letter-spacing: 0.02em;
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: var(--color-ink);
    margin-bottom: var(--space-md);
  }
  .hero-italic { font-style: italic; font-weight: 400; color: var(--color-ink-soft); }
  .hero-mark { position: relative; display: inline-block; color: var(--color-pop); }
  .hero-mark::after {
    content: '';
    position: absolute;
    left: -4px;
    right: -4px;
    bottom: 0.05em;
    height: 0.18em;
    background: var(--color-accent);
    z-index: -1;
    transform: skewX(-6deg);
  }
  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--color-ink-soft);
    max-width: 540px;
    margin-bottom: var(--space-lg);
    line-height: 1.55;
  }
  .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    border-radius: 999px;
    transition: all 0.2s ease;
    text-decoration: none;
  }
  .btn-primary { background: var(--color-ink); color: var(--color-bg); }
  .btn-primary:hover {
    background: var(--color-pop);
    color: var(--color-bg);
    transform: translateY(-1px);
  }
  .btn-ghost {
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--border-color-strong);
  }
  .btn-ghost:hover {
    background: var(--color-ink);
    color: var(--color-bg);
    border-color: var(--color-ink);
  }
  .hero-decor { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
  .decor-shape { position: absolute; border-radius: 50%; }
  .decor-circle {
    top: 10%;
    right: 8%;
    width: 140px;
    height: 140px;
    background: var(--color-accent);
    opacity: 0.5;
    animation: float-slow 8s ease-in-out infinite;
  }
  .decor-blob {
    bottom: 20%;
    right: 18%;
    width: 80px;
    height: 80px;
    background: var(--color-pop);
    opacity: 0.7;
    border-radius: 60% 40% 50% 50%;
    animation: float-slow 10s ease-in-out infinite reverse;
  }
  .decor-dot {
    top: 40%;
    right: 30%;
    width: 16px;
    height: 16px;
    background: var(--color-ink);
    animation: float-bounce 3s ease-in-out infinite;
  }
  @keyframes float-slow {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(-20px, 15px) rotate(8deg); }
    66% { transform: translate(15px, -10px) rotate(-5deg); }
  }
  @keyframes float-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  @media (max-width: 900px) {
    .decor-circle { width: 80px; height: 80px; right: 5%; }
    .decor-blob { width: 50px; height: 50px; right: 12%; }
  }

  /* FEATURED SECTION */
  .featured { padding: var(--space-xl) var(--space-md); }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
    gap: 1rem;
  }
  .section-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.025em;
    color: var(--color-ink);
  }
  .section-link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .section-link:hover { color: var(--color-pop); }

  .feature-row { margin-bottom: 2.5rem; /* 40px — matches tile spacing */ }

  .masonry {
    column-count: 2;
    column-gap: 2.5rem; /* 40px horizontal spacing between columns */
  }
  @media (max-width: 700px) {
    .masonry { column-count: 1; }
  }
</style>
