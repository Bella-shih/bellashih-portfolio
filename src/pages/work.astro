---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectTile from '../components/ProjectTile.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

// Split: first project with size 'feature' goes on top, everything else flows into masonry
const featureProject = projects.find(p => p.data.size === 'feature');
const restProjects = projects.filter(p => p !== featureProject);
---

<BaseLayout title="Work — Bella Shih" description="Commercial and client motion design work.">
  <section class="page-hero container">
    <p class="page-eyebrow">Commercial & client work</p>
    <h1 class="page-title">Work</h1>
    <p class="page-sub">
      Motion design and animation for brands, broadcast, and product teams.
    </p>
  </section>

  <section class="container project-section">
    {projects.length === 0 ? (
      <p class="empty-state">No projects yet. Add Markdown files to <code>src/content/work/</code> to populate this page.</p>
    ) : (
      <>
        {featureProject && (
          <div class="feature-row">
            <ProjectTile
              href={`/projects/${featureProject.id}`}
              title={featureProject.data.title}
              client={featureProject.data.client}
              year={featureProject.data.year?.toString()}
              tags={featureProject.data.tags}
              thumbnail={featureProject.data.thumbnail}
              hoverVideo={featureProject.data.hoverVideo}
              size="feature"
            />
          </div>
        )}

        {restProjects.length > 0 && (
          <div class="masonry">
            {restProjects.map(project => (
              <ProjectTile
                href={`/projects/${project.id}`}
                title={project.data.title}
                client={project.data.client}
                year={project.data.year?.toString()}
                tags={project.data.tags}
                thumbnail={project.data.thumbnail}
                hoverVideo={project.data.hoverVideo}
                size={project.data.size === 'feature' ? 'landscape' : project.data.size}
              />
            ))}
          </div>
        )}
      </>
    )}
  </section>
</BaseLayout>

<style>
  .page-hero { padding: var(--space-xl) var(--space-md) var(--space-lg); }
  .page-eyebrow {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-pop);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(3rem, 8vw, 6rem);
    letter-spacing: -0.035em;
    color: var(--color-ink);
    margin-bottom: var(--space-md);
    font-variation-settings: 'opsz' 72;
  }
  .page-sub {
    font-size: 1.15rem;
    color: var(--color-ink-soft);
    max-width: 600px;
  }
  .project-section { padding: var(--space-lg) var(--space-md) var(--space-xl); }

  .feature-row {
    margin-bottom: 2.5rem; /* 40px — matches tile spacing */
  }

  /* MASONRY — CSS columns layout, fills shortest column first (no gaps) */
  .masonry {
    column-count: 2;
    column-gap: 2.5rem; /* 40px horizontal spacing between columns */
  }

  @media (max-width: 700px) {
    .masonry {
      column-count: 1;
    }
  }

  .empty-state {
    padding: var(--space-xl);
    text-align: center;
    color: var(--color-ink-muted);
    border: 1px dashed var(--border-color-strong);
    border-radius: 12px;
  }
  .empty-state code {
    background: var(--color-accent);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: ui-monospace, monospace;
    font-size: 0.9em;
  }
</style>
