---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const work = await getCollection('work', ({ data }) => !data.draft);
  const personal = await getCollection('personal', ({ data }) => !data.draft);
  const playground = await getCollection('playground', ({ data }) => !data.draft);

  const all = [
    ...work.map(p => ({ ...p, _collection: 'work' as const })),
    ...personal.map(p => ({ ...p, _collection: 'personal' as const })),
    ...playground.map(p => ({ ...p, _collection: 'playground' as const })),
  ];

  return all.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
};

const { project } = Astro.props;
const { Content } = await render(project);
const { data } = project;
---

<BaseLayout title={`${data.title} — Bella Shih`} description={data.description || data.objective}>
  <article class="project">
    <!-- HEADER -->
    <header class="project-header container">
      {data.tags && data.tags.length > 0 && (
        <div class="proj-tags">
          {data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}

      <h1 class="proj-title">{data.title}</h1>

      {data.description && (
        <p class="proj-description">{data.description}</p>
      )}

      <dl class="proj-meta">
        {data.client && (
          <div class="meta-row">
            <dt>Client</dt>
            <dd>{data.client}</dd>
          </div>
        )}
        {data.year && (
          <div class="meta-row">
            <dt>Year</dt>
            <dd>{data.year}</dd>
          </div>
        )}
        {data.role && (
          <div class="meta-row">
            <dt>Role</dt>
            <dd>{data.role}</dd>
          </div>
        )}
      </dl>
    </header>

    <!-- HERO VIDEO OR POSTER -->
    {data.vimeoId ? (
      <div class="proj-video-wrap container">
        <div class="proj-video">
          <iframe
            src={`https://player.vimeo.com/video/${data.vimeoId}?title=0&byline=0&portrait=0`}
            title={data.title}
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    ) : data.poster ? (
      <div class="proj-poster-wrap container">
        <img src={data.poster} alt={data.title} class="proj-poster" />
      </div>
    ) : (
      <div class="proj-poster-wrap container">
        <img src={data.thumbnail} alt={data.title} class="proj-poster" />
      </div>
    )}

    <!-- OBJECTIVE / PROJECT BODY -->
    <div class="proj-body container-narrow">
      {data.objective && (
        <section class="proj-section">
          <h2 class="proj-section-title">Objective</h2>
          <p class="proj-objective">{data.objective}</p>
        </section>
      )}

      <!-- Markdown content from the project file goes here -->
      <div class="proj-content">
        <Content />
      </div>

      <!-- CREDITS -->
      {data.credits && data.credits.length > 0 && (
        <section class="proj-section credits-section">
          <h2 class="proj-section-title">Credits</h2>
          <dl class="credits-list">
            {data.credits.map(credit => (
              <div class="credit-row">
                <dt>{credit.role}</dt>
                <dd>{credit.name}</dd>
              </div>
            ))}
          </dl>
        </section>
      )}
    </div>

    <!-- NAV TO MORE -->
    <nav class="proj-nav container">
      <a href={`/${project._collection}`} class="back-link">
        ← Back to {project._collection.charAt(0).toUpperCase() + project._collection.slice(1)}
      </a>
    </nav>
  </article>
</BaseLayout>

<style>
  /* HEADER */
  .project-header {
    padding: var(--space-xl) var(--space-md) var(--space-lg);
    max-width: 1100px;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: var(--space-md);
  }

  .proj-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: var(--color-ink);
    margin-bottom: var(--space-md);
  }

  .proj-description {
    font-size: clamp(1.1rem, 1.6vw, 1.4rem);
    color: var(--color-ink-soft);
    line-height: 1.5;
    max-width: 680px;
    margin-bottom: var(--space-lg);
  }

  .proj-meta {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
    padding-top: var(--space-md);
    border-top: 1px solid var(--border-color);
  }

  .meta-row dt {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 0.25rem;
  }

  .meta-row dd {
    font-size: 1rem;
    color: var(--color-ink);
    font-weight: 500;
  }

  /* VIDEO / POSTER */
  .proj-video-wrap,
  .proj-poster-wrap {
    padding: 0 var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .proj-video {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 16px;
    overflow: hidden;
    background: var(--color-ink);
    box-shadow: 0 20px 60px -20px rgba(24, 64, 39, 0.3);
  }

  .proj-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .proj-poster {
    width: 100%;
    height: auto;
    border-radius: 16px;
    display: block;
  }

  /* BODY */
  .proj-body {
    padding: 0 var(--space-md);
  }

  .proj-section {
    margin-bottom: var(--space-xl);
  }

  .proj-section-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-pop);
    margin-bottom: var(--space-md);
  }

  .proj-objective {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.4rem, 2.5vw, 1.85rem);
    line-height: 1.4;
    color: var(--color-ink);
    max-width: none;
    letter-spacing: -0.01em;
  }

  /* Markdown content area — applies to anything written in the .md project body */
  .proj-content :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2rem;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: var(--space-xl) 0 var(--space-md);
  }

  .proj-content :global(h3) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-pop);
    margin: var(--space-lg) 0 var(--space-sm);
  }

  .proj-content :global(p) {
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
    margin-bottom: 1.25rem;
    max-width: none;
  }

  .proj-content :global(img) {
    width: 100%;
    height: auto;
    border-radius: 12px;
    margin: var(--space-md) 0;
  }

  .proj-content :global(figure) {
    margin: var(--space-lg) 0;
  }

  .proj-content :global(figcaption) {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin-top: 0.5rem;
    text-align: center;
    font-style: italic;
  }

  /* Image gallery grid — use <div class="gallery"> in your markdown */
  .proj-content :global(.gallery) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
    margin: var(--space-lg) 0;
  }

  .proj-content :global(.gallery img) {
    margin: 0;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  /* Embed video block (for in-content Vimeo embeds) */
  .proj-content :global(.video-embed) {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    margin: var(--space-lg) 0;
    background: var(--color-ink);
  }

  .proj-content :global(.video-embed iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* CREDITS */
  .credits-section {
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border-color);
  }

  .credits-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md) var(--space-lg);
  }

  .credit-row dt {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 0.2rem;
  }

  .credit-row dd {
    font-size: 1rem;
    color: var(--color-ink);
  }

  @media (max-width: 640px) {
    .credits-list { grid-template-columns: 1fr; gap: var(--space-md); }
  }

  /* NAV */
  .proj-nav {
    padding: var(--space-xl) var(--space-md);
    margin-top: var(--space-xl);
    border-top: 1px solid var(--border-color);
  }

  .back-link {
    font-size: 0.95rem;
    color: var(--color-ink-soft);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-pop);
  }
</style>
