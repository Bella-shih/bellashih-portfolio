---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectTile from '../components/ProjectTile.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('personal', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Personal — Bella Shih" description="Personal motion and illustration projects.">
  <section class="page-hero container">
    <p class="page-eyebrow">Personal projects</p>
    <h1 class="page-title">Personal</h1>
    <p class="page-sub">
      Stories, characters, and worlds I make when no one's asking — but I can't help myself.
    </p>
  </section>

  <section class="container project-section">
    {projects.length === 0 ? (
      <p class="empty-state">No projects yet. Add Markdown files to <code>src/content/personal/</code> to populate this page.</p>
    ) : (
      <div class="masonry">
        {projects.map(project => (
          <ProjectTile
            href={`/projects/${project.id}`}
            title={project.data.title}
            client={project.data.client}
            year={project.data.year?.toString()}
            tags={project.data.tags}
            thumbnail={project.data.thumbnail}
            hoverVideo={project.data.hoverVideo}
            size={project.data.size === 'feature' ? 'landscape' : project.data.size}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .page-hero { padding: var(--space-xl) var(--space-md) var(--space-lg); }
  .page-eyebrow {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-pop);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3rem, 8vw, 6rem);
    letter-spacing: -0.035em;
    color: var(--color-ink);
    margin-bottom: var(--space-md);
  }
  .page-sub {
    font-size: 1.15rem;
    color: var(--color-ink-soft);
    max-width: 600px;
  }
  .project-section { padding: var(--space-lg) var(--space-md) var(--space-xl); }

  .masonry {
    column-count: 2;
    column-gap: 2.5rem; /* 40px horizontal spacing between columns */
  }

  @media (max-width: 700px) {
    .masonry {
      column-count: 1;
    }
  }

  .empty-state {
    padding: var(--space-xl);
    text-align: center;
    color: var(--color-ink-muted);
    border: 1px dashed var(--border-color-strong);
    border-radius: 12px;
  }
  .empty-state code {
    background: var(--color-accent);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: ui-monospace, monospace;
    font-size: 0.9em;
  }
</style>
