---
import BaseLayout from '../layouts/BaseLayout.astro';

// To change the reel video: replace this Vimeo ID with your reel's numeric ID
// (find it at vimeo.com/123456789 — the number is the ID)
const REEL_VIMEO_ID = '76979871'; // <-- placeholder; replace with Bella's actual reel ID
const REEL_YEAR = '2025';
---

<BaseLayout title="Reel — Bella Shih" description="A selection of recent motion design work.">
  <section class="reel-page container">
    <header class="reel-header">
      <p class="page-eyebrow">Showreel · {REEL_YEAR}</p>
      <h1 class="reel-title">A few seconds of everything ✦</h1>
    </header>

    <div class="reel-frame">
      <iframe
        src={`https://player.vimeo.com/video/${REEL_VIMEO_ID}?title=0&byline=0&portrait=0&autoplay=0`}
        title="Bella Shih — Showreel"
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>

    <div class="reel-footer">
      <p>Want the full thing? <a href="mailto:hello@bellashih.com">Get in touch</a> for a PDF resume and case studies.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .reel-page {
    padding: var(--space-xl) var(--space-md) var(--space-xl);
  }

  .reel-header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .page-eyebrow {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-pop);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .reel-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    letter-spacing: -0.03em;
    color: var(--color-ink);
    font-variation-settings: 'opsz' 72;
  }

  .reel-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 16px;
    overflow: hidden;
    background: var(--color-ink);
    box-shadow: 0 20px 60px -20px rgba(24, 64, 39, 0.3);
  }

  .reel-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .reel-footer {
    text-align: center;
    margin-top: var(--space-lg);
    color: var(--color-ink-muted);
  }

  .reel-footer a {
    color: var(--color-pop);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
