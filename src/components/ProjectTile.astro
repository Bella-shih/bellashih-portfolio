---
// Project tile — used in grids on Work, Personal, Playground pages
// Shows a thumbnail and (optionally) a hover-triggered video preview loop

interface Props {
  href: string;
  title: string;
  client?: string;
  year?: string | number;
  tags?: string[];
  thumbnail: string;
  hoverVideo?: string; // optional .mp4 / .webm for hover loop
}

const { href, title, client, year, tags = [], thumbnail, hoverVideo } = Astro.props;
---

<a href={href} class="project-tile">
  <div class="tile-media">
    <img
      src={thumbnail}
      alt=""
      class="tile-thumb"
      loading="lazy"
      decoding="async"
    />
    {hoverVideo && (
      <video
        class="tile-hover-video"
        src={hoverVideo}
        muted
        loop
        playsinline
        preload="none"
        aria-hidden="true"
      ></video>
    )}
  </div>

  <div class="tile-meta">
    <h3 class="tile-title">{title}</h3>
    {(client || year) && (
      <p class="tile-sub">
        {client}{client && year ? ' · ' : ''}{year}
      </p>
    )}
    {tags.length > 0 && (
      <div class="tile-tags">
        {tags.map(tag => <span class="tag tag-outline">{tag}</span>)}
      </div>
    )}
  </div>
</a>

<style>
  .project-tile {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
  }

  .tile-media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 12px;
    background: var(--color-accent);
  }

  .tile-thumb,
  .tile-hover-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .tile-hover-video {
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .project-tile:hover .tile-thumb {
    transform: scale(1.04);
  }

  .project-tile:hover .tile-hover-video {
    opacity: 1;
  }

  .tile-meta {
    padding: 0 0.25rem;
  }

  .tile-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 0.25rem;
    transition: color 0.2s ease;
  }

  .project-tile:hover .tile-title {
    color: var(--color-pop);
  }

  .tile-sub {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    margin-bottom: 0.5rem;
  }

  .tile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.25rem;
  }
</style>

<script>
  // Play hover video on mouseenter, pause on mouseleave
  // (separate from CSS opacity so the video resets each time)
  const tiles = document.querySelectorAll('.project-tile');
  tiles.forEach(tile => {
    const video = tile.querySelector('.tile-hover-video') as HTMLVideoElement | null;
    if (!video) return;

    tile.addEventListener('mouseenter', () => {
      video.currentTime = 0;
      video.play().catch(() => {/* autoplay may be blocked, ignore */});
    });

    tile.addEventListener('mouseleave', () => {
      video.pause();
    });
  });
</script>
