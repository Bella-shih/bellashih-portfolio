---
// Project tile — used in mosaic grids on Work, Personal, Playground pages
// Supports size variants: small, medium, tall, wide, feature

interface Props {
  href: string;
  title: string;
  client?: string;
  year?: string | number;
  tags?: string[];
  thumbnail: string;
  hoverVideo?: string;
  size?: 'small' | 'medium' | 'tall' | 'wide' | 'feature';
}

const {
  href,
  title,
  client,
  year,
  tags = [],
  thumbnail,
  hoverVideo,
  size = 'medium',
} = Astro.props;
---

<a href={href} class:list={['project-tile', `tile-${size}`]}>
  <div class="tile-media">
    <img
      src={thumbnail}
      alt=""
      class="tile-thumb"
      loading="lazy"
      decoding="async"
    />
    {hoverVideo && (
      <video
        class="tile-hover-video"
        src={hoverVideo}
        muted
        loop
        playsinline
        preload="none"
        aria-hidden="true"
      ></video>
    )}
  </div>

  <div class="tile-meta">
    <h3 class="tile-title">{title}</h3>
    {(client || year) && (
      <p class="tile-sub">
        {client}{client && year ? ' · ' : ''}{year}
      </p>
    )}
    {tags.length > 0 && (
      <div class="tile-tags">
        {tags.slice(0, 3).map(tag => <span class="tag tag-outline">{tag}</span>)}
      </div>
    )}
  </div>
</a>

<style>
  .project-tile {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
  }

  /* GRID SIZE CLASSES — these get applied to each tile */
  .tile-small {
    grid-column: span 1;
    grid-row: span 1;
  }
  .tile-medium {
    grid-column: span 1;
    grid-row: span 2;
  }
  .tile-tall {
    grid-column: span 1;
    grid-row: span 3;
  }
  .tile-wide {
    grid-column: span 2;
    grid-row: span 2;
  }
  .tile-feature {
    grid-column: span 2;
    grid-row: span 3;
  }

  /* MEDIA — takes up most of the tile, leaves room for meta below */
  .tile-media {
    position: relative;
    width: 100%;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    border-radius: 12px;
    background: var(--color-accent);
  }

  .tile-thumb,
  .tile-hover-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .tile-hover-video {
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .project-tile:hover .tile-thumb {
    transform: scale(1.04);
  }

  .project-tile:hover .tile-hover-video {
    opacity: 1;
  }

  /* META */
  .tile-meta {
    padding: 0 0.25rem;
    flex-shrink: 0;
  }

  .tile-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 0.25rem;
    transition: color 0.2s ease;
  }

  /* Larger title for featured/wide tiles */
  .tile-feature .tile-title,
  .tile-wide .tile-title {
    font-size: 1.75rem;
  }
  .tile-small .tile-title {
    font-size: 1.05rem;
  }

  .project-tile:hover .tile-title {
    color: var(--color-pop);
  }

  .tile-sub {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin-bottom: 0.4rem;
  }

  .tile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.2rem;
  }

  /* MOBILE — collapse mosaic to single column with consistent aspect ratios */
  @media (max-width: 700px) {
    .tile-small,
    .tile-medium,
    .tile-tall,
    .tile-wide,
    .tile-feature {
      grid-column: span 1;
      grid-row: auto;
    }
    .tile-media {
      aspect-ratio: 16 / 10;
      flex: none;
    }
    .tile-feature .tile-media,
    .tile-wide .tile-media {
      aspect-ratio: 16 / 9;
    }
    .tile-tall .tile-media {
      aspect-ratio: 4 / 5;
    }
  }
</style>

<script>
  const tiles = document.querySelectorAll('.project-tile');
  tiles.forEach(tile => {
    const video = tile.querySelector('.tile-hover-video') as HTMLVideoElement | null;
    if (!video) return;

    tile.addEventListener('mouseenter', () => {
      video.currentTime = 0;
      video.play().catch(() => {});
    });

    tile.addEventListener('mouseleave', () => {
      video.pause();
    });
  });
</script>
