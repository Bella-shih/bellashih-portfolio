---
// Project tile — aspect-ratio system designed for masonry layout
// Three sizes:
//   feature   — full-width 24:9 (only used at top of Work / Selected, NOT inside masonry)
//   landscape — 16:9 in a single column
//   square    — 1:1 in a single column

interface Props {
  href: string;
  title: string;
  client?: string;
  year?: string | number;
  tags?: string[];
  thumbnail: string;
  hoverVideo?: string;
  size?: 'feature' | 'landscape' | 'square';
}

const {
  href,
  title,
  client,
  year,
  tags = [],
  thumbnail,
  hoverVideo,
  size = 'landscape',
} = Astro.props;
---

<a href={href} class:list={['project-tile', `tile-${size}`]}>
  <div class="tile-media">
    <img
      src={thumbnail}
      alt=""
      class="tile-thumb"
      loading="lazy"
      decoding="async"
    />
    {hoverVideo && (
      <video
        class="tile-hover-video"
        src={hoverVideo}
        muted
        loop
        playsinline
        preload="none"
        aria-hidden="true"
      ></video>
    )}
  </div>

  <div class="tile-meta">
    <h3 class="tile-title">{title}</h3>
    {(client || year) && (
      <p class="tile-sub">
        {client}{client && year ? ' · ' : ''}{year}
      </p>
    )}
    {tags.length > 0 && (
      <div class="tile-tags">
        {tags.slice(0, 3).map(tag => <span class="tag tag-outline">{tag}</span>)}
      </div>
    )}
  </div>
</a>

<style>
  .project-tile {
    display: block;
    text-decoration: none;
    color: inherit;
    /* break-inside ensures masonry won't split a tile across columns */
    break-inside: avoid;
    -webkit-column-break-inside: avoid;
    page-break-inside: avoid;
    margin-bottom: 2.5rem; /* 40px — vertical spacing between tiles in a column */
  }

  /* MEDIA — aspect ratio locked per size */
  .tile-media {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 12px;
    background: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .tile-feature .tile-media {
    aspect-ratio: 24 / 9;
  }
  .tile-landscape .tile-media {
    aspect-ratio: 16 / 9;
  }
  .tile-square .tile-media {
    aspect-ratio: 1 / 1;
  }

  .tile-thumb,
  .tile-hover-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .tile-hover-video {
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .project-tile:hover .tile-thumb {
    transform: scale(1.04);
  }

  .project-tile:hover .tile-hover-video {
    opacity: 1;
  }

  /* META */
  .tile-meta {
    padding: 0 0.25rem;
  }

  .tile-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 0.25rem;
    transition: color 0.2s ease;
  }

  .tile-feature .tile-title {
    font-size: 2rem;
  }

  .project-tile:hover .tile-title {
    color: var(--color-pop);
  }

  .tile-sub {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    margin-bottom: 0.4rem;
  }

  .tile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.2rem;
  }
</style>

<script>
  const tiles = document.querySelectorAll('.project-tile');
  tiles.forEach(tile => {
    const video = tile.querySelector('.tile-hover-video') as HTMLVideoElement | null;
    if (!video) return;

    tile.addEventListener('mouseenter', () => {
      video.currentTime = 0;
      video.play().catch(() => {});
    });

    tile.addEventListener('mouseleave', () => {
      video.pause();
    });
  });
</script>
