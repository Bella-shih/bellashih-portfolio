---
// Custom cursor
// Two elements: a soft outer circle (slightly delayed) and an inner dot (precise)
// Hides on touch devices; respects reduced motion preference
// To swap for your own art later: replace the .cursor-outer and .cursor-inner SVGs/styling
---

<div class="cursor-outer" aria-hidden="true"></div>
<div class="cursor-inner" aria-hidden="true"></div>

<style>
  .cursor-outer,
  .cursor-inner {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    will-change: transform;
  }

  .cursor-outer {
    width: 28px;
    height: 28px;
    border: 1.5px solid var(--color-ink);
    border-radius: 50%;
    transition: width 0.25s ease, height 0.25s ease, background 0.25s ease, border-color 0.25s ease;
  }

  .cursor-inner {
    width: 6px;
    height: 6px;
    background: var(--color-pop);
    border-radius: 50%;
  }

  /* Grow when hovering over links/buttons */
  .cursor-outer.is-hovering {
    width: 48px;
    height: 48px;
    background: var(--color-accent);
    border-color: transparent;
    mix-blend-mode: multiply;
  }

  /* Hide on touch devices — they don't have a cursor */
  @media (hover: none) {
    .cursor-outer,
    .cursor-inner {
      display: none;
    }
  }
</style>

<script>
  const outer = document.querySelector('.cursor-outer') as HTMLElement | null;
  const inner = document.querySelector('.cursor-inner') as HTMLElement | null;

  if (outer && inner) {
    let mouseX = 0;
    let mouseY = 0;
    let outerX = 0;
    let outerY = 0;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      // inner dot tracks precisely
      inner.style.transform = `translate(${mouseX - 3}px, ${mouseY - 3}px)`;
    });

    // outer circle eases toward mouse for a soft trailing effect
    function animateOuter() {
      const easing = 0.18;
      outerX += (mouseX - outerX) * easing;
      outerY += (mouseY - outerY) * easing;
      outer.style.transform = `translate(${outerX - 14}px, ${outerY - 14}px)`;
      requestAnimationFrame(animateOuter);
    }
    animateOuter();

    // grow on interactive elements
    const interactiveSelectors = 'a, button, [role="button"], input, textarea, .project-tile';
    document.querySelectorAll(interactiveSelectors).forEach((el) => {
      el.addEventListener('mouseenter', () => outer.classList.add('is-hovering'));
      el.addEventListener('mouseleave', () => outer.classList.remove('is-hovering'));
    });
  }
</script>
